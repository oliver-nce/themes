{
  "name": "themes-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run export:tokens && vite build",
    "build:widget": "vite build --config vite.widget.config.js && cp src/widget/theme-swatch-picker.css ../themes/public/dist/theme-swatch-picker.css",
    "build:all": "npm run build && npm run build:widget",
    "preview": "vite preview",
    "export:tokens": "python3 ../scripts/export_theme_tokens.py",
    "test": "vitest run",
    "test:parity": "vitest run src/utils/__tests__/color-shades.parity.test.ts"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "feather-icons": "^4.29.2",
    "frappe-ui": "^0.1.192",
    "socket.io-client": "^4.7.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.2",
    "postcss": "^8.4.5",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.10",
    "vitest": "^3.2.6"
  }
}
