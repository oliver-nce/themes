      "foreground_tonal": { "name": "text-success-fg-tonal", "var": "--nce-color-success-fg-tonal", "status": "shipping" },
      "shade_scale": { "vars": "--nce-color-success-{50…950}", "status": "shipping (curated: 100, 200, 300, 500, 600, 700, 900)", "note": "Other stops remain var-only — use :style with var() if needed." }
    },
    "info": {
      "purpose": "Informational state — neutral notifications, help, tips.",
      "background_class": { "name": "bg-info", "var": "--nce-color-info", "status": "shipping" },
      "text_class":       { "name": "text-info", "var": "--nce-color-info", "status": "shipping" },
