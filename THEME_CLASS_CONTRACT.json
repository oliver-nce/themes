  },
  "escape_hatch": {
    "themed_bg": {
      "class": "bg-themed",
      "purpose": "Single class accepting a runtime --bg CSS variable. Foreground is computed live via OKLCH relative color and follows whatever --bg resolves to.",
      "usage": "<button class=\"bg-themed\" :style=\"{ '--bg': 'var(--nce-color-primary-300)' }\">Dynamic</button>",
      "status": "shipping",
      "browser_support": "Chromium 119+, Safari 16.4+, Firefox 128+"
    }
  },
  "text_roles": {
    "default_body":  { "class": "text-DEFAULT (auto via Tailwind)", "var": "--nce-color-text", "purpose": "Body copy. Applies automatically; rarely set explicitly.", "status": "shipping" },
    "heading":       { "class": "text-heading", "var": "--nce-color-heading", "purpose": "H1–H6 and any prominent text.", "status": "shipping" },
    "muted":         { "class": "text-muted", "var": "--nce-color-muted", "purpose": "Secondary copy — captions, helper text, timestamps.", "status": "shipping" },
    "link":          { "class": "text-link", "var": "--nce-color-link", "purpose": "Hyperlinks.", "status": "shipping" }
  },
  "border_and_focus": {
    "default_border": { "class": "border-DEFAULT (auto via Tailwind)", "var": "--nce-color-border", "purpose": "Card edges, dividers, input borders.", "status": "shipping" },
    "input_border":   { "class": "border-input-border", "var": "--input-border", "purpose": "Form input idle border.", "status": "shipping" },
    "input_focus":    { "class": "border-input-focus", "var": "--input-focus-border", "purpose": "Form input focused border.", "status": "shipping" },
    "focus_ring":     { "class": "ring-focus (manual)", "var": "--nce-color-focus", "purpose": "Keyboard focus ring color.", "status": "shipping" }
  },
  "typography": {
    "font_body":    { "class": "font-sans", "var": "--nce-font-family", "purpose": "Body font.", "status": "shipping" },
    "font_heading": { "class": "font-heading", "var": "--nce-font-heading", "purpose": "Heading font.", "status": "shipping" },
    "sizes": {
      "xs":   { "class": "text-xs", "value": "calc(--nce-font-size * 0.75)", "status": "shipping" },
      "sm":   { "class": "text-sm", "value": "calc(--nce-font-size * 0.875)", "status": "shipping" },
      "base": { "class": "text-base", "value": "--nce-font-size", "status": "shipping" },
      "lg":   { "class": "text-lg", "value": "calc(--nce-font-size * 1.125)", "status": "shipping" },
      "xl":   { "class": "text-xl", "value": "calc(--nce-font-size * 1.25)", "status": "shipping" },
      "2xl":  { "class": "text-2xl", "value": "calc(--nce-font-size * 1.5)", "status": "shipping" },
      "3xl":  { "class": "text-3xl", "value": "calc(--nce-font-size * 1.875)", "status": "shipping" },
      "4xl":  { "class": "text-4xl", "value": "calc(--nce-font-size * 2.25)", "status": "shipping" }
    }
  },
  "shape_and_motion": {
    "radius": {
      "DEFAULT": { "class": "rounded", "var": "--nce-border-radius", "status": "shipping" },
      "sm":      { "class": "rounded-sm", "value": "calc(--nce-border-radius * 0.5)", "status": "shipping" },
      "md":      { "class": "rounded-md", "var": "--nce-border-radius", "status": "shipping" },
      "lg":      { "class": "rounded-lg", "value": "calc(--nce-border-radius * 1.5)", "status": "shipping" },
      "xl":      { "class": "rounded-xl", "value": "calc(--nce-border-radius * 2)", "status": "shipping" }
    },
    "spacing": {
      "xs": { "class": "p-xs / m-xs / gap-xs", "value": "calc(--nce-spacing-base * 0.25)", "status": "shipping" },
      "sm": { "class": "p-sm / m-sm / gap-sm", "value": "calc(--nce-spacing-base * 0.5)", "status": "shipping" },
      "md": { "class": "p-md / m-md / gap-md", "var": "--nce-spacing-base", "status": "shipping" },
      "lg": { "class": "p-lg / m-lg / gap-lg", "value": "calc(--nce-spacing-base * 1.5)", "status": "shipping" },
      "xl": { "class": "p-xl / m-xl / gap-xl", "value": "calc(--nce-spacing-base * 2)", "status": "shipping" }
    },
    "shadow": {
      "DEFAULT": { "class": "shadow", "var": "--nce-shadow", "status": "shipping" },
      "theme":   { "class": "shadow-theme", "var": "--nce-shadow", "status": "shipping" }
    },
    "transition": {
      "theme": { "class": "duration-theme", "var": "--nce-transition-speed", "status": "shipping" }
    }
