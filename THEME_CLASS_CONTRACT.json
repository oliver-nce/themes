      "shade_scale": { "vars": "--nce-color-danger-{50…950}", "status": "shipping (curated: 100, 200, 300, 500, 600, 700, 900)", "note": "Other stops remain var-only — use :style with var() if needed." }
    }
  },
  "neutral_roles": {
    "page_background": { "class": "bg-bg-page", "var": "--nce-color-bg", "purpose": "Page-level background. Default body color.", "status": "shipping" },
    "surface":         { "class": "bg-surface", "var": "--nce-color-surface", "purpose": "Card/panel/modal background — one elevation above the page.", "status": "shipping" },
    "card_alias":      { "class": "bg-card", "var": "--nce-color-surface", "purpose": "Alias of bg-surface for semantic clarity in card components.", "status": "shipping" },
    "row_alt":         { "class": "bg-row-alt", "var": "--nce-color-row-alt", "purpose": "Alternating table row background (zebra striping).", "status": "shipping" },
