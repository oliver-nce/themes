{
  "$schema_purpose": "Public contract of theme-aware classes and CSS variables this app ships. Names are stable; values change when the user re-themes. Use this file when authoring Vue components in this repo or any downstream Frappe app.",
  "source_of_truth": {
    "tailwind_config": "frontend/tailwind.config.js",
    "css_emitter": "themes/utils/css_writer.py",
    "shade_generator": "frontend/src/utils/color-shades.ts"
  },
  "status_legend": {
    "shipping": "Class exists in tailwind.config.js today — safe to use immediately.",
    "var-only": "CSS variable is emitted but no Tailwind class maps to it. Use :style=\"{ ... }\" with var() until a class is added.",
    "proposed": "Not implemented yet. Do not use in production components — included so authors know the planned API."
  },
  "usage_rules": [
    "Prefer Tailwind class names over raw CSS var() — class names are the public API.",
    "Use var() inline only when the token name is dynamic (e.g. looping over palette roles).",
    "Never hardcode hex literals in components. The editor → publish → var() → class chain is broken the moment you do.",
    "For foreground/background pairing, prefer the paired class form (e.g. bg-secondary text-secondary-fg) over hand-picking text-white/text-black."
  ],
  "color_roles": {
    "primary": {
      "purpose": "Main brand color. Default action buttons, primary links, key UI accents.",
      "background_class": { "name": "bg-primary", "var": "--nce-color-primary", "status": "shipping" },
      "text_class":       { "name": "text-primary", "var": "--nce-color-primary", "status": "shipping" },
      "border_class":     { "name": "border-primary", "var": "--nce-color-primary", "status": "shipping" },
      "foreground_mono":  { "name": "text-primary-fg", "var": "--nce-color-primary-fg", "status": "shipping", "description": "Black or white, whichever has best contrast against bg-primary." },
      "foreground_tonal": { "name": "text-primary-fg-tonal", "var": "--nce-color-primary-fg-tonal", "status": "shipping", "description": "Same hue as primary, lightness flipped, chroma reduced." },
      "shade_scale": { "vars": "--nce-color-primary-{50,100,200,300,400,500,600,700,800,900,950}", "status": "shipping (curated: 100, 200, 300, 500, 600, 700, 900)", "note": "Other stops remain var-only — use :style with var() if needed." }
    },
    "secondary": {
      "purpose": "Supporting brand color. Secondary buttons, headers, alternate emphasis.",
      "background_class": { "name": "bg-secondary", "var": "--nce-color-secondary", "status": "shipping" },
      "text_class":       { "name": "text-secondary", "var": "--nce-color-secondary", "status": "shipping" },
      "border_class":     { "name": "border-secondary", "var": "--nce-color-secondary", "status": "shipping" },
      "foreground_mono":  { "name": "text-secondary-fg", "var": "--nce-color-secondary-fg", "status": "shipping" },
      "foreground_tonal": { "name": "text-secondary-fg-tonal", "var": "--nce-color-secondary-fg-tonal", "status": "shipping" },
      "shade_scale": { "vars": "--nce-color-secondary-{50…950}", "status": "shipping (curated: 100, 200, 300, 500, 600, 700, 900)", "note": "Other stops remain var-only — use :style with var() if needed." }
    },
    "accent": {
      "purpose": "Highlight color for emphasis, callouts, decorative accents.",
      "background_class": { "name": "bg-accent", "var": "--nce-color-accent", "status": "shipping" },
      "text_class":       { "name": "text-accent", "var": "--nce-color-accent", "status": "shipping" },
      "border_class":     { "name": "border-accent", "var": "--nce-color-accent", "status": "shipping" },
