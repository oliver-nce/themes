      "shade_scale": { "vars": "--nce-color-warning-{50…950}", "status": "shipping (curated: 100, 200, 300, 500, 600, 700, 900)", "note": "Other stops remain var-only — use :style with var() if needed." }
    },
    "danger": {
      "purpose": "Error/destructive state — failures, delete buttons, critical alerts.",
      "background_class": { "name": "bg-danger", "var": "--nce-color-danger", "status": "shipping" },
      "text_class":       { "name": "text-danger", "var": "--nce-color-danger", "status": "shipping" },
      "foreground_mono":  { "name": "text-danger-fg", "var": "--nce-color-danger-fg", "status": "shipping" },
