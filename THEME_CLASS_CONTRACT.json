  "examples_for_authors": {
    "primary_button": "<button class=\"bg-primary rounded px-md py-sm\">Primary</button>",
    "header_row_tonal_after_fg_lands": "<th class=\"bg-secondary text-secondary-fg-tonal px-md py-sm font-heading\">FRAPPE DOCTYPE</th>",
    "row_of_buttons_uniform_text": "<div class=\"flex gap-sm text-white\"><button class=\"bg-primary\">A</button><button class=\"bg-secondary\">B</button><button class=\"bg-accent\">C</button></div>",
    "shade_used_inline_today_var_only": "<div :style=\"{ background: 'var(--nce-color-primary-100)', color: 'var(--nce-color-primary-900)' }\">Card</div>",
